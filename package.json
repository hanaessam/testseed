{
  "name": "testseed",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:docker": "docker compose up --build",
    "lint": "turbo run lint",
    "setup:dev": "node scripts/setup-dev.mjs",
    "env:production:init": "node scripts/init-production-env.mjs",
    "env:production:sync": "node scripts/sync-production-env.mjs",
    "test": "turbo run test",
    "health": "npm install && npm run test:suite",
    "test:suite": "node scripts/test-suite.mjs",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.9.16",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@10.9.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "pptxgenjs": "^4.0.1"
  }
}
