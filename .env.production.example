# Production secrets and URLs for TestSeed.
# Copy to .env.production (gitignored), fill secrets, then run:
#   node scripts/sync-production-env.mjs

OPENAI_API_KEY=
MONGODB_URI=
REDIS_URL=https://your-upstash-redis-url.upstash.io
REDIS_TOKEN=
JWT_SECRET=
OTP_TTL_SECONDS=600
OTP_MAX_ATTEMPTS=5
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="TestSeed <no-reply@your-domain.com>"

NEXT_PUBLIC_API_URL=https://testseed-api.vercel.app
NEXT_PUBLIC_GENERATION_WORKBENCH_STREAMING=true
NEXT_PUBLIC_GENERATION_WORKBENCH_EXPORT=true
WEB_APP_URL=https://testseed-web.vercel.app

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=https://testseed-api.vercel.app/auth/github/callback

# GitHub Actions deploy secrets (synced with scripts/sync-github-secrets.mjs)
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_WEB_PROJECT_ID=
VERCEL_API_PROJECT_ID=
