{
  "$schema": "https://turborepo.com/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "env": [
        "OPENAI_API_KEY",
        "NEXT_PUBLIC_API_URL",
        "NEXT_PUBLIC_GENERATION_WORKBENCH_STREAMING",
        "NEXT_PUBLIC_GENERATION_WORKBENCH_EXPORT",
        "VERCEL",
        "VERCEL_ENV",
        "NODE_ENV"
      ],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"]
    }
  }
}
